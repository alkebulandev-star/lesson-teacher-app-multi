{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/anthropic.ts":  { "maxDuration": 300 },
    "api/openai.ts":     { "maxDuration": 300 },
    "api/elevenlabs.ts": { "maxDuration": 120 },
    "api/health.ts":     { "maxDuration": 10  }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
